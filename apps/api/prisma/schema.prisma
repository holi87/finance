generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  personal
  business
  company
  shared
}

enum MembershipRole {
  owner
  editor
  viewer
}

enum AccountType {
  cash
  bank
  savings
  credit
  investment
}

enum CategoryKind {
  expense
  income
  both
}

enum TransactionType {
  expense
  income
  transfer
}

enum PeriodType {
  monthly
}

enum ReminderScheduleType {
  once
  monthly
}

enum SyncEntityType {
  workspace
  account
  category
  transaction
  budgetPeriod
  budgetLimit
  reminder
}

enum SyncOperationType {
  create
  update
  delete
}

enum SyncReceiptStatus {
  applied
  failed
  conflict
}

model User {
  id                  String           @id @default(uuid()) @db.Uuid
  email               String           @unique
  passwordHash        String           @map("password_hash")
  displayName         String           @map("display_name")
  isActive            Boolean          @default(true) @map("is_active")
  isSystemAdmin       Boolean          @default(false) @map("is_system_admin")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz()
  lastLoginAt         DateTime?        @map("last_login_at") @db.Timestamptz()
  ownedWorkspaces     Workspace[]      @relation("WorkspaceOwner")
  memberships         Membership[]
  devices             Device[]
  refreshSessions     RefreshSession[]
  createdTransactions Transaction[]    @relation("TransactionCreator")
  syncChanges         SyncChange[]     @relation("SyncChangeAuthor")
  syncCursors         SyncCursor[]
  invitedMemberships  Membership[]     @relation("MembershipInvitedBy")
  auditLogs           AuditLog[]

  @@map("users")
}

model RefreshSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_sessions")
}

model Device {
  id           String                 @id @default(uuid()) @db.Uuid
  userId       String                 @map("user_id") @db.Uuid
  deviceName   String                 @map("device_name")
  platform     String
  lastSeenAt   DateTime?              @map("last_seen_at") @db.Timestamptz()
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime               @updatedAt @map("updated_at") @db.Timestamptz()
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncReceipts SyncOperationReceipt[]
  syncCursors  SyncCursor[]

  @@map("devices")
}

model Workspace {
  id            String                 @id @default(uuid()) @db.Uuid
  name          String
  slug          String
  type          WorkspaceType
  baseCurrency  String                 @map("base_currency") @db.VarChar(3)
  ownerId       String                 @map("owner_id") @db.Uuid
  archivedAt    DateTime?              @map("archived_at") @db.Timestamptz()
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime               @updatedAt @map("updated_at") @db.Timestamptz()
  owner         User                   @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  accounts      Account[]
  categories    Category[]
  reminders     Reminder[]
  transactions  Transaction[]
  transferLinks TransferLink[]
  budgetPeriods BudgetPeriod[]
  budgetLimits  BudgetLimit[]
  syncChanges   SyncChange[]
  syncReceipts  SyncOperationReceipt[]
  syncCursors   SyncCursor[]
  auditLogs     AuditLog[]

  @@unique([ownerId, slug])
  @@map("workspaces")
}

model Membership {
  id            String         @id @default(uuid()) @db.Uuid
  workspaceId   String         @map("workspace_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  role          MembershipRole
  invitedBy     String?        @map("invited_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser User?          @relation("MembershipInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([workspaceId, userId])
  @@map("memberships")
}

model Account {
  id                   String        @id @default(uuid()) @db.Uuid
  workspaceId          String        @map("workspace_id") @db.Uuid
  name                 String
  type                 AccountType
  currency             String        @db.VarChar(3)
  openingBalance       Decimal       @default(0) @map("opening_balance") @db.Decimal(18, 2)
  currentBalanceCached Decimal       @default(0) @map("current_balance_cached") @db.Decimal(18, 2)
  isArchived           Boolean       @default(false) @map("is_archived")
  version              Int           @default(1)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt            DateTime?     @map("deleted_at") @db.Timestamptz()
  workspace            Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  reminders            Reminder[]

  @@index([workspaceId, isArchived])
  @@index([workspaceId, deletedAt])
  @@map("accounts")
}

model Category {
  id               String        @id @default(uuid()) @db.Uuid
  workspaceId      String        @map("workspace_id") @db.Uuid
  parentCategoryId String?       @map("parent_category_id") @db.Uuid
  name             String
  kind             CategoryKind
  color            String?
  icon             String?
  isArchived       Boolean       @default(false) @map("is_archived")
  version          Int           @default(1)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime?     @map("deleted_at") @db.Timestamptz()
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentCategory   Category?     @relation("CategoryTree", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories  Category[]    @relation("CategoryTree")
  transactions     Transaction[]
  budgetLimits     BudgetLimit[]
  reminders        Reminder[]

  @@index([workspaceId, kind])
  @@index([workspaceId, deletedAt])
  @@map("categories")
}

model Transaction {
  id               String          @id @default(uuid()) @db.Uuid
  workspaceId      String          @map("workspace_id") @db.Uuid
  accountId        String          @map("account_id") @db.Uuid
  categoryId       String?         @map("category_id") @db.Uuid
  type             TransactionType
  amount           Decimal         @db.Decimal(18, 2)
  currency         String          @db.VarChar(3)
  description      String?
  notes            String?
  transactionDate  DateTime        @map("transaction_date") @db.Date
  createdBy        String          @map("created_by") @db.Uuid
  version          Int             @default(1)
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz()
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdByUser    User            @relation("TransactionCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  outboundTransfer TransferLink?   @relation("OutboundTransfer")
  inboundTransfer  TransferLink?   @relation("InboundTransfer")

  @@index([workspaceId, transactionDate(sort: Desc)])
  @@index([workspaceId, accountId])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, deletedAt])
  @@index([workspaceId, updatedAt])
  @@map("transactions")
}

model TransferLink {
  id                    String      @id @default(uuid()) @db.Uuid
  workspaceId           String      @map("workspace_id") @db.Uuid
  outboundTransactionId String      @unique @map("outbound_transaction_id") @db.Uuid
  inboundTransactionId  String      @unique @map("inbound_transaction_id") @db.Uuid
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  workspace             Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outboundTransaction   Transaction @relation("OutboundTransfer", fields: [outboundTransactionId], references: [id], onDelete: Cascade)
  inboundTransaction    Transaction @relation("InboundTransfer", fields: [inboundTransactionId], references: [id], onDelete: Cascade)

  @@map("transfer_links")
}

model BudgetPeriod {
  id           String        @id @default(uuid()) @db.Uuid
  workspaceId  String        @map("workspace_id") @db.Uuid
  periodType   PeriodType    @map("period_type")
  startsAt     DateTime      @map("starts_at") @db.Date
  endsAt       DateTime      @map("ends_at") @db.Date
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  budgetLimits BudgetLimit[]

  @@map("budget_periods")
}

model BudgetLimit {
  id             String       @id @default(uuid()) @db.Uuid
  workspaceId    String       @map("workspace_id") @db.Uuid
  budgetPeriodId String       @map("budget_period_id") @db.Uuid
  categoryId     String       @map("category_id") @db.Uuid
  amount         Decimal      @db.Decimal(18, 2)
  currency       String       @db.VarChar(3)
  version        Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz()
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  budgetPeriod   BudgetPeriod @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, budgetPeriodId, categoryId])
  @@index([workspaceId, budgetPeriodId])
  @@map("budget_limits")
}

model Reminder {
  id              String               @id @default(uuid()) @db.Uuid
  workspaceId     String               @map("workspace_id") @db.Uuid
  title           String
  notes           String?
  amount          Decimal              @db.Decimal(18, 2)
  currency        String               @db.VarChar(3)
  accountId       String?              @map("account_id") @db.Uuid
  categoryId      String?              @map("category_id") @db.Uuid
  scheduleType    ReminderScheduleType @map("schedule_type")
  dueDate         DateTime?            @map("due_date") @db.Date
  dueDayOfMonth   Int?                 @map("due_day_of_month")
  isActive        Boolean              @default(true) @map("is_active")
  lastCompletedAt DateTime?            @map("last_completed_at") @db.Date
  version         Int                  @default(1)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime?            @map("deleted_at") @db.Timestamptz()
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account         Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category        Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([workspaceId, isActive])
  @@index([workspaceId, scheduleType])
  @@index([workspaceId, deletedAt])
  @@map("reminders")
}

model SyncChange {
  id              BigInt            @id @default(autoincrement())
  workspaceId     String            @map("workspace_id") @db.Uuid
  entityType      SyncEntityType    @map("entity_type")
  entityId        String            @map("entity_id") @db.Uuid
  operationType   SyncOperationType @map("operation_type")
  entityVersion   Int               @map("entity_version")
  changedBy       String?           @map("changed_by") @db.Uuid
  changedAt       DateTime          @default(now()) @map("changed_at") @db.Timestamptz()
  payloadSnapshot Json?             @map("payload_snapshot")
  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  changedByUser   User?             @relation("SyncChangeAuthor", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([workspaceId, id])
  @@index([workspaceId, changedAt])
  @@index([workspaceId, entityType, entityId])
  @@map("sync_changes")
}

model SyncOperationReceipt {
  id            BigInt            @id @default(autoincrement())
  operationId   String            @map("operation_id")
  deviceId      String            @map("device_id") @db.Uuid
  workspaceId   String            @map("workspace_id") @db.Uuid
  entityType    SyncEntityType    @map("entity_type")
  entityId      String            @map("entity_id") @db.Uuid
  operationType SyncOperationType @map("operation_type")
  entityVersion Int               @map("entity_version")
  processedAt   DateTime          @default(now()) @map("processed_at") @db.Timestamptz()
  resultStatus  SyncReceiptStatus @map("result_status")
  device        Device            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([operationId, deviceId])
  @@map("sync_operation_receipts")
}

model SyncCursor {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  deviceId           String    @map("device_id") @db.Uuid
  workspaceId        String    @map("workspace_id") @db.Uuid
  lastPulledChangeId BigInt    @default(0) @map("last_pulled_change_id")
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device             Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId, workspaceId])
  @@map("sync_cursors")
}

model AuditLog {
  id          String     @id @default(uuid()) @db.Uuid
  action      String
  userId      String?    @map("user_id") @db.Uuid
  workspaceId String?    @map("workspace_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}
